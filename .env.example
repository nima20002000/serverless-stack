# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/commerce?schema=public"

# Application URLs
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Site defaults
NEXT_PUBLIC_SITE_NAME="Supabase Vercel Stack"
NEXT_PUBLIC_SITE_DESCRIPTION="Open-source commerce boilerplate for Supabase and Vercel."
NEXT_PUBLIC_SITE_LANGUAGE="en"
NEXT_PUBLIC_SITE_DIRECTION="ltr"
NEXT_PUBLIC_SITE_LOCALE="en-US"
NEXT_PUBLIC_SITE_CURRENCY="USD"
NEXT_PUBLIC_SITE_TIME_ZONE="UTC"

# Authentication
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Supabase
# Get values from Supabase Dashboard > Project Settings > API.
# Use publishable/secret keys. Do not expose SUPABASE_SECRET_KEY in client code.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"
SUPABASE_SECRET_KEY="replace-with-supabase-secret-key"

# Stripe payment
STRIPE_SECRET_KEY="sk_test_replace_with_your_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_with_your_key"
STRIPE_WEBHOOK_SECRET="whsec_replace_with_your_secret"
# Optional, defaults to NEXT_PUBLIC_SITE_CURRENCY
STRIPE_CURRENCY="usd"

# Optional neutral label used in provider checkout/order descriptions
PAYMENT_SITE_NAME="Commerce Starter"

# PayPal payment
PAYPAL_CLIENT_ID="replace-with-paypal-client-id"
PAYPAL_CLIENT_SECRET="replace-with-paypal-client-secret"
PAYPAL_WEBHOOK_ID="replace-with-paypal-webhook-id"
# Allowed values: sandbox | live
PAYPAL_ENV="sandbox"
# Optional, defaults to NEXT_PUBLIC_SITE_CURRENCY
PAYPAL_CURRENCY="USD"

# Logging
LOG_LEVEL="info"

# Optional: Upstash Redis cache and rate limiting
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-token"

# Optional: Email delivery
# Development can use Ethereal or any SMTP account when SMTP variables are set.
EMAIL_FROM='"Commerce Starter" <noreply@example.com>'
ADMIN_EMAIL="admin@example.com"
RESEND_API_KEY="re_replace_with_resend_key"

# Optional: Resend SMTP mode
# RESEND_SMTP="true"
# RESEND_SMTP_HOST="smtp.resend.com"
# RESEND_SMTP_PORT="587"
# RESEND_SMTP_SECURE="false"
# RESEND_SMTP_USER="resend"
# RESEND_SMTP_PASS="replace-with-resend-api-key"

# Optional: Custom SMTP
# EMAIL_SMTP_HOST="smtp.example.com"
# EMAIL_SMTP_PORT="587"
# EMAIL_SMTP_SECURE="false"
# EMAIL_SMTP_USER="user@example.com"
# EMAIL_SMTP_PASS="replace-with-smtp-password"

# Optional: Cloudflare R2-compatible product media storage
R2_ACCOUNT_ID="replace-with-cloudflare-account-id"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
R2_BUCKET_NAME="commerce-media"
R2_PUBLIC_URL="https://media.example.com"
NEXT_PUBLIC_IMAGE_REMOTE_HOSTNAME="media.example.com"

# Optional: R2 backup helper configuration
R2_BACKUP_BUCKET_NAME="commerce-backups"
R2_BACKUP_ACCESS_KEY_ID="replace-with-r2-backup-access-key-id"
R2_BACKUP_SECRET_ACCESS_KEY="replace-with-r2-backup-secret-access-key"
BACKUP_FILE_PATHS="app-env=.env.production"

# Optional: Cloudflare Image Resizing
# Set to "false" to disable image transformations.
NEXT_PUBLIC_CLOUDFLARE_IMAGE_RESIZING_ENABLED="true"
