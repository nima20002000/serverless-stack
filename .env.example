# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kitia?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Stripe Payment
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
# Optional (defaults to usd)
STRIPE_CURRENCY="usd"

# Application URL (used for SEO metadata, sitemap, robots.txt)
# Development: http://localhost:3000
# Production: https://kitia.ir
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PayPal Payment
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"
# Allowed values: sandbox | live
PAYPAL_ENV="sandbox"
# Optional (defaults to USD)
PAYPAL_CURRENCY="USD"

# Logging
LOG_LEVEL="info"

# Redis Cache (Upstash)
# Get credentials from https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Email (Order notifications)
# Development: Uses Ethereal (auto-created test account) if not configured
# Production: Use Resend API key (https://resend.com)
EMAIL_FROM='"کیتیا" <noreply@kitia.ir>'
ADMIN_EMAIL="admin@kitia.ir"

# For Production (Resend) - Domain verified: kitia.ir
RESEND_API_KEY="re_xxxxxxxxxxxx"

# For Development (Optional - Custom SMTP/Ethereal):
# EMAIL_SMTP_HOST="smtp.ethereal.email"
# EMAIL_SMTP_PORT="587"
# EMAIL_SMTP_SECURE="false"
# EMAIL_SMTP_USER="your-ethereal-user@ethereal.email"
# EMAIL_SMTP_PASS="your-ethereal-password"

# Cloudflare R2 Storage (for product images/videos)
# Get credentials from Cloudflare Dashboard > R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="kitia-products"
# Production: https://cdn.kitia.ir (custom domain)
# Development: Can use R2.dev subdomain or same as production
R2_PUBLIC_URL="https://your-bucket.your-domain.com"

# Cloudflare Image Resizing (Optional)
# Set to "false" to disable image optimization and use raw images
# Default: true (enabled)
# IMPORTANT: You must enable Image Resizing in Cloudflare Dashboard first!
# See: https://dash.cloudflare.com → Images → Transformations
NEXT_PUBLIC_CLOUDFLARE_IMAGE_RESIZING_ENABLED="true"

# Supabase Configuration
# Get credentials from Supabase Dashboard → Project Settings → API
# Use the NEW Publishable/Secret keys (not legacy anon/service_role)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_SECRET_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
