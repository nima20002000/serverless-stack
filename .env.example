# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kitia?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Zarinpal Payment Gateway
ZARINPAL_MERCHANT_ID="test"
ZARINPAL_SANDBOX="true"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Logging
LOG_LEVEL="info"

# Redis Cache (Upstash)
# Get credentials from https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Kavenegar SMS (OTP)
# Get credentials from https://panel.kavenegar.com
KAVENEGAR_API_KEY="your-api-key-here"
KAVENEGAR_SENDER="2000660110"
KAVENEGAR_TEMPLATE_NAME="otp-test"

# Email (OTP & Notifications)
# Development: Uses Ethereal (auto-created test account) if not configured
# Production: Use Resend API key (https://resend.com)
EMAIL_FROM='"کیتیا" <noreply@kitia.ir>'

# For Production (Resend) - Domain verified: kitia.ir
RESEND_API_KEY="re_xxxxxxxxxxxx"

# For Development (Optional - Custom SMTP/Ethereal):
# EMAIL_SMTP_HOST="smtp.ethereal.email"
# EMAIL_SMTP_PORT="587"
# EMAIL_SMTP_SECURE="false"
# EMAIL_SMTP_USER="your-ethereal-user@ethereal.email"
# EMAIL_SMTP_PASS="your-ethereal-password"
