{
  "project": "Kitia E-commerce Platform",
  "stack": {
    "framework": "Next.js 14+ (App Router)",
    "database": "PostgreSQL",
    "orm": "Prisma",
    "auth": "NextAuth.js",
    "stateManagement": "Zustand",
    "styling": "Tailwind CSS",
    "icons": "Heroicons",
    "payment": "Zarinpal SDK",
    "language": "TypeScript",
    "direction": "RTL (Right-to-Left)"
  },
  "architecture": {
    "pattern": "Service Layer Architecture",
    "description": "Modular architecture with clear separation of concerns, business logic centralized in services, API routes as thin controllers"
  },
  "structure": {
    "/src": {
      "/app": {
        "description": "Next.js App Router - All routes and pages",
        "/api": {
          "description": "API endpoints",
          "/auth/[...nextauth]": "NextAuth authentication endpoints",
          "/products": "Product CRUD operations",
          "/transactions": "Payment and transaction handling",
          "/invoices": "Invoice generation and retrieval",
          "/admin": "Admin-only operations"
        },
        "/(public)": {
          "description": "Public-facing routes",
          "/products": "Product listing and detail pages",
          "/checkout": "Checkout flow",
          "/invoice/[id]": "Downloadable invoice page"
        },
        "/(auth)": {
          "description": "Authentication routes",
          "/login": "Login page",
          "/register": "Registration page"
        },
        "/admin": {
          "description": "Admin panel routes",
          "/products": "Product management",
          "/users": "User management",
          "/transactions": "Transaction overview"
        }
      },
      "/components": {
        "description": "Reusable React components",
        "/ui": "Base UI components (buttons, inputs, cards, etc.)",
        "/products": "Product-related components (card, list, form)",
        "/admin": "Admin-specific components (tables, dashboards)",
        "/invoice": "Invoice template and components",
        "/layout": "Layout components (Header, Footer, RTL-aware wrappers)"
      },
      "/lib": {
        "description": "Core utilities and configurations",
        "/prisma": "Prisma client initialization and schema",
        "/auth": "NextAuth configuration and providers",
        "/zarinpal": "Zarinpal SDK wrapper and utilities",
        "/utils": "Helper functions and utilities"
      },
      "/services": {
        "description": "Business logic layer - Core application logic",
        "user-service.ts": "User operations (create, update, get user data)",
        "product-service.ts": "Product operations (CRUD, inventory)",
        "transaction-service.ts": "Transaction logic, payment processing, code generation",
        "invoice-service.ts": "Invoice generation and PDF creation",
        "promo-service.ts": "Promotional codes, first-time user logic, timer management",
        "admin-service.ts": "Admin operations (user control, product management)"
      },
      "/store": {
        "description": "Zustand state management stores",
        "cart-store.ts": "Shopping cart state",
        "user-store.ts": "User session and preferences",
        "admin-store.ts": "Admin panel state"
      },
      "/types": {
        "description": "TypeScript type definitions",
        "models.ts": "Database model types (auto-generated from Prisma)",
        "api.ts": "API request/response types",
        "index.ts": "Exported types"
      },
      "/middleware": {
        "description": "Next.js middleware",
        "auth-middleware.ts": "Route protection and role-based access control"
      },
      "/config": {
        "description": "Application configuration",
        "constants.ts": "Application constants (API URLs, limits, etc.)",
        "site.ts": "Site metadata, RTL config, SEO defaults"
      }
    }
  },
  "database": {
    "models": {
      "User": {
        "fields": [
          "id (String, UUID)",
          "email (String, unique)",
          "password (String, hashed)",
          "name (String)",
          "role (Enum: USER, ADMIN)",
          "createdAt (DateTime)",
          "updatedAt (DateTime)",
          "firstTimePromoCode (String, nullable)"
        ],
        "relations": ["transactions", "promoCodes"]
      },
      "Product": {
        "fields": [
          "id (String, UUID)",
          "name (String)",
          "description (String)",
          "price (Decimal)",
          "stock (Int)",
          "images (String[])",
          "isActive (Boolean)",
          "createdAt (DateTime)",
          "updatedAt (DateTime)"
        ],
        "relations": ["transactionItems"]
      },
      "Transaction": {
        "fields": [
          "id (String, UUID)",
          "userId (String)",
          "amount (Decimal)",
          "status (Enum: PENDING, COMPLETED, FAILED)",
          "transactionCode (String, unique)",
          "zarinpalAuthority (String, nullable)",
          "createdAt (DateTime)",
          "updatedAt (DateTime)"
        ],
        "relations": ["user", "items", "invoice"]
      },
      "TransactionItem": {
        "fields": [
          "id (String, UUID)",
          "transactionId (String)",
          "productId (String)",
          "quantity (Int)",
          "price (Decimal)"
        ],
        "relations": ["transaction", "product"]
      },
      "Invoice": {
        "fields": [
          "id (String, UUID)",
          "transactionId (String, unique)",
          "invoiceNumber (String, unique)",
          "generatedAt (DateTime)",
          "pdfUrl (String, nullable)"
        ],
        "relations": ["transaction"]
      },
      "PromoCode": {
        "fields": [
          "id (String, UUID)",
          "code (String, unique)",
          "userId (String, unique)",
          "expiresAt (DateTime)",
          "isUsed (Boolean)",
          "createdAt (DateTime)"
        ],
        "relations": ["user"]
      }
    }
  },
  "features": {
    "firstTimeUserFlow": {
      "description": "24-hour timer with unique promo code for new users",
      "implementation": "Triggered on user registration, stored in PromoCode model, displayed via header component with countdown timer",
      "service": "promo-service.ts"
    },
    "transactionFlow": {
      "description": "Payment processing with unique transaction codes",
      "steps": [
        "User initiates checkout",
        "Generate unique transaction code",
        "Redirect to Zarinpal",
        "Verify payment callback",
        "Update transaction status",
        "Generate invoice"
      ],
      "service": "transaction-service.ts"
    },
    "invoiceSystem": {
      "description": "Downloadable invoices for completed transactions",
      "implementation": "PDF generation on transaction completion, stored reference in database",
      "service": "invoice-service.ts"
    },
    "adminPanel": {
      "description": "Simple CRUD operations for products and user management",
      "features": [
        "Product creation, editing, deletion",
        "User list and role management",
        "Transaction overview",
        "Stock management"
      ],
      "protection": "Role-based middleware, admin-only routes"
    }
  },
  "configuration": {
    "rtl": {
      "implementation": "Root layout with dir='rtl', Tailwind RTL utilities, Persian/Arabic font support"
    },
    "authentication": {
      "strategy": "NextAuth with credentials provider",
      "session": "JWT-based",
      "protection": "Middleware for route protection"
    },
    "payment": {
      "provider": "Zarinpal",
      "flow": "Request → Redirect → Verify → Update"
    }
  },
  "expandability": {
    "principles": [
      "Service-oriented architecture allows easy addition of new business logic",
      "Modular component structure for UI expansion",
      "API routes can be extended without affecting existing ones",
      "Database schema migrations handled by Prisma",
      "New payment providers can be added alongside Zarinpal",
      "Additional admin features can be added to /admin routes"
    ]
  },
  "dependencies": {
    "core": [
      "next",
      "react",
      "react-dom",
      "typescript",
      "@types/node",
      "@types/react",
      "@types/react-dom"
    ],
    "database": [
      "@prisma/client",
      "prisma"
    ],
    "authentication": [
      "next-auth",
      "bcryptjs",
      "@types/bcryptjs"
    ],
    "stateManagement": [
      "zustand"
    ],
    "styling": [
      "tailwindcss",
      "postcss",
      "autoprefixer",
      "@heroicons/react"
    ],
    "payment": [
      "zarinpal-checkout"
    ],
    "utilities": [
      "date-fns",
      "date-fns-jalali",
      "uuid",
      "@types/uuid"
    ],
    "pdf": [
      "pdfkit",
      "@types/pdfkit"
    ]
  }
}
