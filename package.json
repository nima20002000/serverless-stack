{
  "name": "supabase-vercel-stack",
  "version": "0.1.0",
  "description": "Open-source commerce boilerplate for Next.js, Supabase, Vercel, Stripe, and PayPal.",
  "license": "MIT",
  "scripts": {
    "dev": "npm cache clean --force && rm -rf .next && next dev --webpack 2>&1 | pino-pretty -c -t 'HH:MM:ss' -i pid,hostname",
    "dev:plain": "npm cache clean --force && rm -rf .next && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "verify:routes": "bash scripts/verify-api-routes.sh",
    "verify:config": "bash scripts/verify-config-files.sh",
    "verify": "npm run verify:config && npm run verify:routes",
    "check": "npm run verify && npm run lint && npm run test:unit && npm run build",
    "test:ci": "npm run test:unit",
    "prebuild": "npm run verify && node scripts/generate-build-version.js",
    "predev": "npm run verify:config",
    "test": "npm --prefix tests run test --",
    "test:all": "npm --prefix tests run test:all --",
    "test:unit": "npm --prefix tests run test:unit --",
    "test:integration": "npm --prefix tests run test:integration --",
    "test:e2e": "npm --prefix tests run test:e2e --",
    "unit": "npm --prefix tests run test:unit --",
    "integration": "npm --prefix tests run test:integration --",
    "e2e": "npm --prefix tests run test:e2e --",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/lib-storage": "^3.943.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.1.0",
    "@smithy/node-http-handler": "^4.4.5",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.88.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.7",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5",
    "libphonenumber-js": "^1.12.30",
    "next": "^16.2.6",
    "next-auth": "^4.24.0",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.15.0",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.6.0",
    "server-only": "^0.0.1",
    "stripe": "^20.3.1",
    "uuid": "^14.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@chromatic-com/storybook": "^4.1.3",
    "@next/eslint-plugin-next": "^16.2.6",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/nextjs-vite": "^10.1.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.0",
    "critters": "^0.0.23",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.1.11",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.2",
    "playwright": "^1.57.0",
    "postcss": "^8.5.14",
    "prettier": "^3.7.4",
    "storybook": "^10.1.11",
    "supabase": "^2.67.2",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "postcss": "$postcss",
    "uuid": "$uuid",
    "glob": "10.5.0"
  }
}
