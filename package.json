{
  "name": "kitia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev 2>&1 | pino-pretty -c -t 'HH:MM:ss' -i pid,hostname",
    "dev:plain": "rm -rf .next && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "verify:routes": "bash scripts/verify-api-routes.sh",
    "prebuild": "npm run verify:routes"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.1.0",
    "@prisma/client": "^5.14.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.7",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "date-fns-jalali": "^3.6.0-1",
    "kavenegar": "^1.1.4",
    "libphonenumber-js": "^1.12.30",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.15.0",
    "pino": "^10.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^9.0.1",
    "zarinpal-node-sdk": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "pino-pretty": "^13.1.2",
    "postcss": "^8.4.0",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
