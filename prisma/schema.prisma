// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PaymentMethod {
  ZARINPAL
  DIGIPAY
}

model User {
  id              String   @id @default(uuid())
  uid             String   @unique // Human-readable ID: U-000001
  email           String?  @unique
  phone           String?  @unique
  password        String?
  name            String
  role            Role     @default(USER)
  isVerified      Boolean  @default(false)
  shippingAddress String?  @db.Text
  postalCode      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions Transaction[]
  promoCodes   PromoCode[]

  @@map("users")
  @@index([email])
  @@index([phone])
  @@index([uid])
}

model Product {
  id             String   @id @default(uuid())
  name           String
  description    String   @db.Text
  price          Decimal  @db.Decimal(10, 2)
  discountPercent Int?    // Discount percentage (0-100)
  stock          Int      @default(0)
  images         String[] // Deprecated - kept for backward compatibility
  categoryId     String?
  hasVariants    Boolean  @default(false) // If true, product uses variant system (variant stock/price override product values)
  isFeatured     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category         Category?         @relation(fields: [categoryId], references: [id])
  tags             Tag[]
  media            ProductMedia[]
  variants         ProductVariant[]
  transactionItems TransactionItem[]

  @@map("products")
  @@index([isActive])
  @@index([isFeatured])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  image       String?   // Category card image URL
  parentId    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]

  @@map("tags")
}

model ProductMedia {
  id        String    @id @default(uuid())
  productId String
  variantId String?
  type      MediaType
  url       String
  alt       String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("product_media")
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  name        String
  sku         String?  @unique
  color       String?
  size        String?
  material    String?
  priceAdjust Decimal  @default(0) @db.Decimal(10, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  media            ProductMedia[]
  transactionItems TransactionItem[]

  @@map("product_variants")
}

model Transaction {
  id                 String            @id @default(uuid())
  userId             String?
  amount             Decimal           @db.Decimal(10, 2)
  status             TransactionStatus @default(PENDING)
  transactionCode    String            @unique
  // Payment gateway tracking
  paymentMethod      PaymentMethod     @default(ZARINPAL)
  isGuest            Boolean           @default(true)
  zarinpalAuthority  String?
  zarinpalRefId      String?
  // Shipping information (stored on transaction for both guest and registered users)
  fullName           String            @default("")
  phone              String            @default("")
  email              String?
  shippingAddress    String            @default("") @db.Text
  postalCode         String?
  // Flag to create account after payment (for guest users)
  createAccount      Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user    User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   TransactionItem[]
  invoice Invoice?

  @@map("transactions")
  @@index([userId, createdAt(sort: Desc)])
  @@index([paymentMethod])
  @@index([isGuest])
}

model TransactionItem {
  id            String  @id @default(uuid())
  transactionId String
  productId     String
  variantId     String? // Optional: Which variant was purchased (null for products without variants)
  quantity      Int
  price         Decimal @db.Decimal(10, 2)

  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("transaction_items")
}

model Invoice {
  id            String   @id @default(uuid())
  transactionId String   @unique
  invoiceNumber String   @unique
  generatedAt   DateTime @default(now())
  pdfUrl        String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model PromoCode {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("promo_codes")
  @@index([userId, isUsed])
}

model OTPVerification {
  id          String   @id @default(uuid())
  identifier  String   // Email or phone number
  code        String
  purpose     String   // "register" | "login" | "reset-password"
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("otp_verifications")
  @@index([identifier, purpose])
}

model SiteSettings {
  id        String   @id @default(uuid())
  key       String   @unique // "favicon" | "logo" | "site_name" | etc
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
