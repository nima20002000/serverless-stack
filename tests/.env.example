# Supabase Configuration (Test Environment)
# Get keys from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co

# Use a publishable key for browser/client tests and a secret key only for
# server-side integration tests.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>
SUPABASE_SECRET_KEY=<your-supabase-secret-key>
# Required when NEXT_PUBLIC_SUPABASE_URL is not localhost.
TEST_ALLOW_DESTRUCTIVE_DB=I_UNDERSTAND_TEST_DATABASE_IS_DESTRUCTIVE
# Optional comma-separated refs that should never be used by test helpers.
TEST_BLOCKED_SUPABASE_REFS=ref_one,ref_two

# Database Connection
DATABASE_URL=postgresql://postgres:<password>@db.your-test-project.supabase.co:5432/postgres

# Upstash Redis (Test instance recommended)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token
# Required when Redis credentials are configured because cleanup deletes keys.
TEST_ALLOW_SHARED_REDIS=I_UNDERSTAND_TEST_REDIS_IS_DESTRUCTIVE

# Email Service (Resend - Test mode)
RESEND_API_KEY=re_test_key
EMAIL_FROM="Commerce Test" <test@example.com>

# Stripe (test/sandbox)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=usd

# PayPal (sandbox)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=USD

# Storage (Cloudflare R2 - Test bucket)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=commerce-test
R2_PUBLIC_URL=https://cdn.example.com
AWS_EC2_METADATA_DISABLED=true

# Test Configuration
TEST_USER_EMAIL=test@example.com
TEST_USER_PHONE=+15555550100
TEST_USER_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=AdminPassword123!

# Contract Recording (set to true to record real API responses)
RECORD_CONTRACTS=false
CONTRACT_VALIDATION_STRICT=true
