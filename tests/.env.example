# Supabase Configuration (Preview/Test Environment)
NEXT_PUBLIC_SUPABASE_URL=https://gozxjxtnrbuurmstjydo.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

# Upstash Redis (Test instance recommended)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Email Service (Resend - Test mode)
RESEND_API_KEY=re_test_key
EMAIL_FROM="کیتیا تست" <test@kitia.ir>

# SMS Service (Kavenegar - Test template)
KAVENEGAR_API_KEY=your_test_api_key
KAVENEGAR_TEMPLATE_NAME=kitia-test-otp

# Payment Gateway (Zarinpal - Sandbox mode)
ZARINPAL_MERCHANT_ID=test_merchant
ZARINPAL_SANDBOX=true

# Storage (Cloudflare R2 - Test bucket)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=kitia-test
R2_PUBLIC_URL=https://test-cdn.kitia.ir
AWS_EC2_METADATA_DISABLED=true

# Test Configuration
TEST_USER_EMAIL=test@example.com
TEST_USER_PHONE=09120000000
TEST_USER_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=AdminPassword123!

# Contract Recording (set to true to record real API responses)
RECORD_CONTRACTS=false
CONTRACT_VALIDATION_STRICT=true
