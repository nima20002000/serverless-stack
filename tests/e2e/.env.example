# E2E Test Environment Configuration
# Copy this to .env and configure for your E2E test environment

# CRITICAL: NEVER use live credentials
# Use separate Supabase project/database for E2E tests

# Next.js
E2E_BASE_URL=http://localhost:3000

# Supabase (MUST be a disposable test instance)
E2E_SUPABASE_URL=https://your-e2e-project.supabase.co
E2E_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>
E2E_SUPABASE_SECRET_KEY=<your-supabase-secret-key>
# Required for destructive helpers when E2E_SUPABASE_URL is not localhost.
E2E_ALLOW_DESTRUCTIVE_DB=I_UNDERSTAND_E2E_DATABASE_IS_DESTRUCTIVE
# Optional deterministic OTP accepted by your test app when OTPs are not stored.
E2E_STATIC_OTP_CODE=123456
# Optional comma-separated refs that should never be used by E2E helpers.
E2E_BLOCKED_SUPABASE_REFS=ref_one,ref_two

# Upstash Redis (MUST be test database)
E2E_UPSTASH_REDIS_REST_URL=https://your-e2e-redis.upstash.io
E2E_UPSTASH_REDIS_REST_TOKEN=your-token

# Cloudflare R2 (MUST be test bucket)
E2E_R2_BUCKET_NAME=commerce-e2e-test
E2E_R2_ACCESS_KEY_ID=your-key
E2E_R2_SECRET_ACCESS_KEY=your-secret

# Payments (use sandbox/mock mode)
E2E_MOCK_PAYMENTS=true

# Currency display override for configured-currency E2E coverage.
# Uncomment these for the focused configured-currency spec.
# These are mapped to NEXT_PUBLIC_SITE_* for the Playwright web server.
# E2E_SITE_CURRENCY=JPY
# E2E_SITE_LOCALE=ja-JP
# E2E_SITE_CURRENCY_DISPLAY=code
# E2E_SITE_DIRECTION=rtl

# Email (mock in E2E, use deterministic OTP when auth flows need it)
E2E_MOCK_EMAIL=true
