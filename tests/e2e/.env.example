# E2E Test Environment Configuration
# Copy this to .env and configure for your E2E test environment

# CRITICAL: NEVER use production credentials
# Use separate Supabase project/database for E2E tests

# Next.js
E2E_BASE_URL=http://localhost:3000

# Supabase (MUST be test/preview instance)
E2E_SUPABASE_URL=https://your-e2e-project.supabase.co
E2E_SUPABASE_PUBLISHABLE_KEY=eyJhbGc...
E2E_SUPABASE_SECRET_KEY=eyJhbGc...

# Upstash Redis (MUST be test database)
E2E_UPSTASH_REDIS_REST_URL=https://your-e2e-redis.upstash.io
E2E_UPSTASH_REDIS_REST_TOKEN=your-token

# Cloudflare R2 (MUST be test bucket)
E2E_R2_BUCKET_NAME=kitia-e2e-test
E2E_R2_ACCESS_KEY_ID=your-key
E2E_R2_SECRET_ACCESS_KEY=your-secret

# Payment Gateway (Use SANDBOX mode)
E2E_MOCK_PAYMENTS=true

# SMS/Email (Mock in E2E, retrieve OTP from database)
E2E_MOCK_SMS=true
E2E_MOCK_EMAIL=true
