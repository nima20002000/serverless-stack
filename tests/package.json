{
  "name": "kitia-tests",
  "version": "1.0.0",
  "description": "Test suite for Kitia e-commerce platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e:chromium",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:watch": "vitest watch --config vitest.config.unit.ts",
    "test:unit:parallel": "vitest run --config vitest.config.unit.ts --reporter=verbose",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest watch --config vitest.config.integration.ts",
    "test:integration:fast": "node scripts/run-integration-fast.js",
    "test:ui": "vitest --ui --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "test:coverage:all": "vitest run --coverage",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "mock:record": "node scripts/record-contracts.js",
    "mock:validate": "node scripts/validate-contracts.js",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:chromium": "playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:firefox": "playwright test --config=e2e/playwright.config.ts --project=firefox",
    "test:e2e:mobile": "playwright test --config=e2e/playwright.config.ts --project=mobile",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.88.0",
    "@upstash/redis": "^1.35.7",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "dotenv": "^16.4.5",
    "jsdom": "^24.1.3",
    "msw": "^2.6.8",
    "typescript": "^5.4.0",
    "undici": "^6.25.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
