{
  "name": "kitia-integration-tests",
  "version": "1.0.0",
  "description": "Integration and contract testing suite for Kitia e-commerce platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "mock:record": "node scripts/record-contracts.js",
    "mock:validate": "node scripts/validate-contracts.js",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:chromium": "playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:firefox": "playwright test --config=e2e/playwright.config.ts --project=firefox",
    "test:e2e:mobile": "playwright test --config=e2e/playwright.config.ts --project=mobile",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.88.0",
    "@upstash/redis": "^1.35.7",
    "date-fns": "^3.6.0",
    "date-fns-jalali": "^3.6.0-1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.8",
    "dotenv": "^16.4.5",
    "msw": "^2.6.8",
    "typescript": "^5.4.0",
    "undici": "^6.21.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
