{
  "name": "kitia-tests",
  "version": "1.0.0",
  "description": "Test suite for Kitia e-commerce platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo 'Error: Use npm run test:unit or npm run test:integration' && exit 1",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:watch": "vitest watch --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest watch --config vitest.config.integration.ts",
    "test:ui": "vitest --ui --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "mock:record": "node scripts/record-contracts.js",
    "mock:validate": "node scripts/validate-contracts.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.88.0",
    "@upstash/redis": "^1.35.7",
    "date-fns": "^3.6.0",
    "date-fns-jalali": "^3.6.0-1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.8",
    "dotenv": "^16.4.5",
    "msw": "^2.6.8",
    "typescript": "^5.4.0",
    "undici": "^6.21.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
